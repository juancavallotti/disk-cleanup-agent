{
  "name": "disk-cleanup",
  "version": "0.1.0",
  "description": "CLI app with Commander, LangChain, and OpenAI — skills-based design",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "disk-cleanup": "./dist/index.js"
  },
  "scripts": {
    "dev": "ENV=dev NODE_OPTIONS='--import ./scripts/register-md.mjs' tsx src/index.ts",
    "dev:watch": "ENV=dev NODE_OPTIONS='--import ./scripts/register-md.mjs' tsx watch src/index.ts",
    "build": "tsc && tsc-alias -p tsconfig.json && node scripts/copy-skills.mjs",
    "start": "node --import ./scripts/register-md.mjs dist/index.js",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "keywords": [
    "cli",
    "commander",
    "langchain",
    "openai"
  ],
  "license": "MIT",
  "dependencies": {
    "@inquirer/input": "^4.1.0",
    "@inquirer/select": "^5.1.0",
    "@langchain/anthropic": "^1.0.0",
    "@langchain/core": "^1.1.16",
    "@langchain/langgraph": "^1.2.0",
    "@langchain/openai": "^1.0.0",
    "commander": "^12.0.0",
    "dotenv": "^17.3.1",
    "langchain": "^1.2.28",
    "openai": "^4.0.0",
    "yaml": "^2.6.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
