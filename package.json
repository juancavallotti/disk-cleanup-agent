{
  "name": "disk-cleanup",
  "version": "0.1.0",
  "description": "CLI app with Commander, LangChain, and OpenAI — skills-based design",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "disk-cleanup": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && tsc-alias -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "keywords": [
    "cli",
    "commander",
    "langchain",
    "openai"
  ],
  "license": "MIT",
  "dependencies": {
    "@langchain/core": "^0.3.0",
    "@langchain/openai": "^0.3.0",
    "commander": "^12.0.0",
    "openai": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
